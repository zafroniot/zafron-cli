{
  "name": "zafron",
  "version": "0.1.0",
  "description": "CLI tool for the Zafron IoT platform",
  "main": "dist/index.js",
  "bin": {
    "zafron": "./bin/zafron"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "build:binaries": "npm run build && pkg . --out-path dist/binaries",
    "build:macos": "npm run build && pkg . --targets node20-macos-x64,node20-macos-arm64 --out-path dist/binaries",
    "build:linux": "npm run build && pkg . --targets node20-linux-x64,node20-linux-arm64 --out-path dist/binaries",
    "build:windows": "npm run build && pkg . --targets node20-win-x64 --out-path dist/binaries",
    "build:all": "npm run build && pkg . --targets node20-macos-x64,node20-macos-arm64,node20-linux-x64,node20-linux-arm64,node20-win-x64 --out-path dist/binaries"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [],
    "targets": [
      "node20-macos-x64",
      "node20-macos-arm64",
      "node20-linux-x64",
      "node20-linux-arm64",
      "node20-win-x64"
    ],
    "outputPath": "dist/binaries"
  },
  "keywords": [
    "zafron",
    "iot",
    "cli"
  ],
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "@yao-pkg/pkg": "^6.14.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
